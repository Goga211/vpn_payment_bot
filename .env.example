# Токен бота из @BotFather
BOT_TOKEN=

# Панель Remnawave: ТОЛЬКО origin, без /api в конце.
# Замените panel.example.com на реальный домен панели.
REMNAWAVE_BASE_URL=https://panel.example.com
# Авторизация: используйте ЛИБО токен, ЛИБО логин + пароль.
REMNAWAVE_TOKEN=
REMNAWAVE_USERNAME=
REMNAWAVE_PASSWORD=
REMNAWAVE_TIMEOUT=12

# URL страницы оплаты, открываемой как Telegram Mini App (обязательно HTTPS).
PAYMENT_URL=https://aiyl-bank.ru/checkout

# Необязательное
# Ссылка на чат/контакт техподдержки (кнопка «🆘 Техподдержка»).
SUPPORT_URL=
# Ссылка для отзывов и предложений (кнопка «💬 Отзывы и предложения»).
# Если не задано — кнопка использует SUPPORT_URL.
FEEDBACK_URL=
BRAND_NAME=Nimbus
